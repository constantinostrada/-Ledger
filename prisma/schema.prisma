generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT
  INVESTMENT
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum RecurrenceInterval {
  DAILY
  WEEKLY
  MONTHLY
}

model User {
  id           String    @id
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash")
  name         String?   @db.VarChar(100)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @map("updated_at")
  accounts     Account[]
  budgets      Budget[]

  @@map("users")
}

model Account {
  id             String          @id
  userId         String          @map("user_id")
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String          @db.VarChar(100)
  type           AccountType
  // Balance is intentionally NOT stored: it is always derived from the
  // account's transactions so it can never drift.
  currency       String          @default("USD") @db.Char(3)
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @default(now()) @map("updated_at")
  transactions   Transaction[]
  recurringRules RecurringRule[]

  @@index([userId])
  @@map("accounts")
}

model Transaction {
  id              String          @id
  accountId       String          @map("account_id")
  account         Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId      String?         @map("category_id")
  category        Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  recurringRuleId String?         @map("recurring_rule_id")
  recurringRule   RecurringRule?  @relation(fields: [recurringRuleId], references: [id], onDelete: SetNull)
  // Money is ALWAYS integer cents — never floats/decimals.
  amountCents     Int             @map("amount_cents")
  currency        String          @default("USD") @db.Char(3)
  type            TransactionType
  note            String          @db.VarChar(500)
  date            DateTime
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @default(now()) @map("updated_at")

  // One materialized transaction per rule + due date: this is what makes the
  // recurring sweep idempotent by construction (re-runs conflict and skip).
  @@unique([recurringRuleId, date])
  @@index([accountId])
  @@index([categoryId])
  @@index([date])
  @@map("transactions")
}

model RecurringRule {
  id           String             @id
  accountId    String             @map("account_id")
  account      Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId   String?            @map("category_id")
  category     Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  // Money is ALWAYS integer cents — never floats/decimals.
  amountCents  Int                @map("amount_cents")
  currency     String             @default("USD") @db.Char(3)
  type         TransactionType
  note         String             @db.VarChar(500)
  interval     RecurrenceInterval
  // First due date; later occurrences derive from it per the interval.
  startDate    DateTime           @map("start_date")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @default(now()) @map("updated_at")
  transactions Transaction[]

  @@index([accountId])
  @@map("recurring_rules")
}

model Category {
  id             String          @id
  name           String          @unique @db.VarChar(100)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @default(now()) @map("updated_at")
  transactions   Transaction[]
  budgets        Budget[]
  recurringRules RecurringRule[]

  @@map("categories")
}

model Budget {
  id         String   @id
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  // Money is ALWAYS integer cents — never floats/decimals.
  limitCents Int      @map("limit_cents")
  currency   String   @default("USD") @db.Char(3)
  // Calendar month the budget covers, formatted YYYY-MM. Spent-vs-limit is
  // NOT stored: it is always derived from the transactions in this period.
  period     String   @db.Char(7)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @map("updated_at")

  @@unique([userId, categoryId, period])
  @@index([userId, period])
  @@map("budgets")
}
